# Copy this file to .env and fill with your Firebase credentials
# Do NOT commit your .env to version control. Add .env to .gitignore if needed.

# For Firebase Admin (backend service account JSON) you can either paste the
# full JSON here (not recommended) or set the path to the service account file.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/serviceAccountKey.json
# Or minimal key fields as a JSON string (escape newlines) - optional
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# For Firebase client (frontend), use the web config values
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id

# Optional: a port or env mode for backend
PORT=3000
NODE_ENV=development
